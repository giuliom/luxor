# Runtime. Outside production an empty DATABASE_URL starts the embedded
# PostgreSQL server (data in .luxor/) and an empty REDIS_URL selects the
# in-memory cache and queue, so no Docker is needed. Point them at real
# services to use those instead, for example the Compose ones:
#   DATABASE_URL=postgres://luxor:luxor@localhost:5432/luxor
#   REDIS_URL=redis://127.0.0.1:6379/
# Production startup requires DATABASE_URL, REDIS_URL, and a unique 32+
# character JWT_SECRET.
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8080
DATABASE_URL=
REDIS_URL=
# Compose host ports. If a port is busy, change it here and update its URL above.
POSTGRES_PORT=5432
REDIS_PORT=6379
JWT_SECRET=development-only-secret-change-me
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
# Absolute cap on refresh-token rotation: a session ends at the latest this
# many seconds after login, no matter how often it refreshes. Must be at
# least REFRESH_TOKEN_TTL_SECONDS.
REFRESH_FAMILY_TTL_SECONDS=7776000
REFRESH_COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:8080
BODY_LIMIT_BYTES=1048576
# End-to-end deadline for handling one request, including reading its body.
REQUEST_TIMEOUT_SECONDS=30
AUTO_MIGRATE=true
APP_OPEN_BROWSER=false
CACHE_NAMESPACE=luxor:cache
QUEUE_KEY=luxor:queue:jobs

# Rate limiting. Budgets are per client IP within a fixed window; the auth
# budget covers /api/auth (login, register, refresh, logout) on top of the
# API-wide one. Backed by Redis when REDIS_URL is set, otherwise in-memory.
# RATE_LIMIT_ENABLED cannot be false in production.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_MAX_REQUESTS=10
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
RATE_LIMIT_API_MAX_REQUESTS=120
RATE_LIMIT_API_WINDOW_SECONDS=60
RATE_LIMIT_NAMESPACE=luxor:ratelimit
# How the client IP is determined: "socket" (direct connections; the default
# outside production) or "x-forwarded-for" (the rightmost proxy-appended
# entry; the default in production, where a platform proxy fronts the app).
# Never use x-forwarded-for without a trusted proxy: clients can forge it.
CLIENT_IP_SOURCE=

# Observability is disabled when these are empty.
RUST_LOG=luxor=info,tower_http=info,sqlx=warn
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=luxor
# Host ports used by the optional Compose observability profile.
OTEL_GRPC_PORT=4317
JAEGER_UI_PORT=16686
SENTRY_DSN=

# OAuth is optional and provider-agnostic. If one field is set, all five are required.
OAUTH_AUTHORIZATION_URL=
OAUTH_TOKEN_URL=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URL=
