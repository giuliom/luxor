# Runtime. Development/test may use these documented local defaults; production
# startup requires DATABASE_URL, REDIS_URL, and a unique 32+ character JWT_SECRET.
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8080
DATABASE_URL=postgres://luxor:luxor@localhost:5432/luxor
REDIS_URL=redis://127.0.0.1:6379/
# Compose host ports. If a port is busy, change it here and update its URL above.
POSTGRES_PORT=5432
REDIS_PORT=6379
JWT_SECRET=development-only-secret-change-me
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
REFRESH_COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:8080
BODY_LIMIT_BYTES=1048576
AUTO_MIGRATE=true
APP_STANDALONE=false
APP_OPEN_BROWSER=false
CACHE_NAMESPACE=luxor:cache
QUEUE_KEY=luxor:queue:jobs

# Observability is disabled when these are empty.
RUST_LOG=luxor=info,tower_http=info,sqlx=warn
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=luxor
# Host ports used by the optional Compose observability profile.
OTEL_GRPC_PORT=4317
JAEGER_UI_PORT=16686
SENTRY_DSN=

# OAuth is optional and provider-agnostic. If one field is set, all five are required.
OAUTH_AUTHORIZATION_URL=
OAUTH_TOKEN_URL=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URL=
