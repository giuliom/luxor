{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "luxor: start infrastructure",
      "type": "process",
      "command": "docker",
      "args": [
        "compose",
        "up",
        "--detach",
        "--wait",
        "postgres",
        "redis"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    }
  ]
}
