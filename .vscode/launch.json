{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug luxor",
      "type": "lldb",
      "request": "launch",
      "cargo": {
        "args": ["build", "--bin", "luxor"],
        "filter": {
          "name": "luxor",
          "kind": "bin"
        }
      },
      "args": [],
      "cwd": "${workspaceFolder}",
      "terminal": "integrated",
      "env": {
        "APP_ENV": "development",
        "APP_HOST": "127.0.0.1",
        "APP_OPEN_BROWSER": "true",
        // Explicitly empty so a .env file cannot re-point this Docker-free
        // configuration at external services: empty means "use the embedded
        // PostgreSQL server and the in-memory cache and queue".
        "DATABASE_URL": "",
        "REDIS_URL": "",
        "REFRESH_COOKIE_SECURE": "false",
        "RUST_BACKTRACE": "1",
        "RUST_LOG": "luxor=info,tower_http=info,sqlx=warn,redis=warn",
        "PORT": "8080"
      },
      "sourceLanguages": ["rust"]
    },
    {
      "name": "Debug luxor (Docker PostgreSQL + Redis)",
      "type": "lldb",
      "request": "launch",
      "cargo": {
        "args": ["build", "--bin", "luxor"],
        "filter": {
          "name": "luxor",
          "kind": "bin"
        }
      },
      "args": [],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "luxor: start infrastructure",
      "terminal": "integrated",
      "env": {
        "APP_ENV": "development",
        "APP_HOST": "127.0.0.1",
        "APP_OPEN_BROWSER": "true",
        "DATABASE_URL": "postgres://luxor:luxor@localhost:5432/luxor",
        "REDIS_URL": "redis://127.0.0.1:6379/",
        "AUTO_MIGRATE": "true",
        "REFRESH_COOKIE_SECURE": "false",
        "RUST_BACKTRACE": "1",
        "RUST_LOG": "luxor=info,tower_http=info,sqlx=warn,redis=warn",
        "PORT": "8080"
      },
      "sourceLanguages": ["rust"]
    },
    {
      "name": "Tests: unit (lib)",
      "type": "lldb",
      "request": "launch",
      "cargo": {
        "args": ["test", "--no-run", "--lib", "--all-features"],
        "filter": {
          "name": "luxor",
          "kind": "lib"
        }
      },
      "args": ["--nocapture"],
      "cwd": "${workspaceFolder}",
      "env": {
        "RUST_BACKTRACE": "1"
      },
      "sourceLanguages": ["rust"]
    },
    {
      "name": "Tests: integration (infrastructure)",
      "type": "lldb",
      "request": "launch",
      "cargo": {
        "args": ["test", "--no-run", "--test", "infrastructure", "--all-features"],
        "filter": {
          "name": "infrastructure",
          "kind": "test"
        }
      },
      "args": ["--nocapture"],
      "cwd": "${workspaceFolder}",
      "env": {
        "RUST_BACKTRACE": "1",
        "DATABASE_URL": "postgres://luxor:luxor@localhost:5432/luxor",
        "REDIS_URL": "redis://127.0.0.1:6379/"
      },
      "sourceLanguages": ["rust"]
    }
  ],
  "compounds": [
    {
      "name": "Run all tests",
      "configurations": ["Tests: unit (lib)", "Tests: integration (infrastructure)"],
      "stopAll": true
    }
  ]
}
