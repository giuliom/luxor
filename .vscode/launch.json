{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug luxor",
      "type": "lldb",
      "request": "launch",
      "cargo": {
        "args": ["build", "--bin", "luxor"],
        "filter": {
          "name": "luxor",
          "kind": "bin"
        }
      },
      "args": [],
      "cwd": "${workspaceFolder}",
      "env": {
        "RUST_BACKTRACE": "1",
        "PORT": "3001"
      },
      "serverReadyAction": {
        "pattern": "listening on (127\\.0\\.0\\.1:[0-9]+)",
        "uriFormat": "http://%s/",
        "action": "openExternally"
      },
      "sourceLanguages": ["rust"]
    },
    {
      "name": "Tests: unit (lib)",
      "type": "lldb",
      "request": "launch",
      "cargo": {
        "args": ["test", "--no-run", "--lib", "--all-features"],
        "filter": {
          "name": "luxor",
          "kind": "lib"
        }
      },
      "args": ["--nocapture"],
      "cwd": "${workspaceFolder}",
      "env": {
        "RUST_BACKTRACE": "1"
      },
      "sourceLanguages": ["rust"]
    },
    {
      "name": "Tests: integration (infrastructure)",
      "type": "lldb",
      "request": "launch",
      "cargo": {
        "args": ["test", "--no-run", "--test", "infrastructure", "--all-features"],
        "filter": {
          "name": "infrastructure",
          "kind": "test"
        }
      },
      "args": ["--nocapture"],
      "cwd": "${workspaceFolder}",
      "env": {
        "RUST_BACKTRACE": "1",
        "DATABASE_URL": "postgres://luxor:luxor@localhost:5432/luxor",
        "REDIS_URL": "redis://127.0.0.1:6379/"
      },
      "sourceLanguages": ["rust"]
    }
  ],
  "compounds": [
    {
      "name": "Run all tests",
      "configurations": ["Tests: unit (lib)", "Tests: integration (infrastructure)"],
      "stopAll": true
    }
  ]
}
